{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit --pretty 2>&1 | head -20",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "node scripts/check-x-weight.js",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
